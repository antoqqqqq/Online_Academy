<div class="container mt-5">
    <!-- 1️⃣ Course Header -->
    <div class="row mb-4">
        <div class="col-lg-8">
            <h1 class="fw-bold mb-3">Khoá học {{course.title}}</h1>
            <p class="text-muted">{{course.description}}</p>

            <!-- Rating, reviews, students -->
            <div class="d-flex align-items-center gap-3 mb-3">
                <div class="text-warning">
                    ★ {{course.rating}} / 5
                </div>
                <div class="text-muted">
                    ({{course.total_reviews}} đánh giá)
                </div>
                <div class="text-muted">
                    • {{course.total_enrollment}} học viên đã đăng ký
                </div>
            </div>

            <!-- Pricing -->
            <div class="mb-4">
                {{#if course.is_onsale}}
                <h3 class="text-danger fw-bold mb-0">
                    Học phí: {{format_money course.current_price}}
                </h3>
                <small class="text-muted text-decoration-line-through">
                    Học phí gốc: {{format_money course.original_price}}
                </small>
                {{else}}
                <h3 class="fw-bold">Học phí: {{format_money course.current_price}}₫</h3>
                {{/if}}
            </div>

            <!-- Last updated -->
            <p class="text-muted">
                <small>Lần cập nhật cuối: {{course.latest_update}}</small>
            </p>
        </div>

        <!-- 2️⃣ Course Image -->
        <div class="col-lg-4 text-center">
            {{!-- <img src="https://images.pexels.com/photos/821944/pexels-photo-821944.jpeg?cs=srgb&dl=pexels-george-desipris-821944.jpg&fm=jpg"
                alt="{{course.title}}" class="img-fluid rounded shadow"> --}}
            <img src="{{course.image_url}}" alt="{{course.title}}" class="img-fluid rounded shadow">


        </div>
    </div>

    <hr>

    <div class="container mt-5">
        <div class="row">
            <!-- 🧩 LEFT SIDE (10 parts) -->
            <div class="col-lg-10 col-md-12">

                <!-- 3️⃣ Full description -->
                <section class="mb-5">
                    <h3 class="mb-3">Nội dung của khoá học</h3>

                    {{#if course.full_description.overview}}
                    <div class="mb-4">
                        <h5>📘 Tổng quan</h5>
                        <p>{{course.full_description.overview}}</p>
                        <p>Độ khó: {{course.level}}</p>
                        <p>Số giờ: {{course.total_hours}}</p>
                        <p>Số lớp: {{course.total_lectures}}</p>
                    </div>
                    {{/if}}

                    {{#if course.full_description.what_you_will_learn}}
                    <div class="mb-4">
                        <h5>🎯 Bạn sẽ học được gì</h5>
                        <ul>
                            {{#each course.full_description.what_you_will_learn}}
                            <li>{{this}}</li>
                            {{/each}}
                        </ul>
                    </div>
                    {{/if}}

                    {{#if course.full_description.requirements}}
                    <div class="mb-4">
                        <h5>🧰 Yêu cầu</h5>
                        <ul>
                            {{#each course.full_description.requirements}}
                            <li>{{this}}</li>
                            {{/each}}
                        </ul>
                    </div>
                    {{/if}}
                </section>

                <!-- 4️⃣ Course outline / preview -->
                <section class="mb-5">
                    <h3 class="mb-3">Đề cương khoá học</h3>

                    <div class="accordion" id="courseOutline">
                        {{#each lectures}}
                        <div class="accordion-item">
                            <h2 class="accordion-header" id="heading-{{@index}}">
                                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse"
                                    data-bs-target="#collapse-{{@index}}">
                                    {{this.title}}
                                </button>
                            </h2>

                            <div id="collapse-{{@index}}" class="accordion-collapse collapse"
                                data-bs-parent="#courseOutline">
                                <div class="accordion-body">
                                    {{#if this.description}}
                                    <p class="text-muted mb-2"><strong>Mô tả:</strong> {{this.description}}</p>
                                    {{/if}}

                                    {{#if this.full_description.overview}}
                                    <p><strong>Tổng quan:</strong> {{this.full_description.overview}}</p>
                                    {{/if}}

                                    {{#if this.full_description.objectives}}
                                    <div class="mb-2">
                                        <strong>Mục tiêu:</strong>
                                        <ul class="mb-0">
                                            {{#each this.full_description.objectives}}
                                            <li>{{this}}</li>
                                            {{/each}}
                                        </ul>
                                    </div>
                                    {{/if}}

                                    {{#if this.time}}
                                    <p class="mb-1"><strong>Thời lượng:</strong> {{this.time}} phút</p>
                                    {{/if}}

                                    {{#if this.is_preview}}
                                    <a href="/lecture/{{this.id}}" class="btn btn-sm btn-outline-primary mt-2">🎬 Xem
                                        trước</a>
                                    {{/if}}
                                </div>
                            </div>
                        </div>
                        {{/each}}
                    </div>
                </section>




            </div>

            <!-- 🧑‍🏫 RIGHT SIDE (2 parts) -->
            <div class="col-lg-2 col-md-12">
                <section class="mb-5 sticky-top" style="top: 80px;">
                    <h3 class="mb-3">Thông tin giảng viên</h3>
                    <div class="card border-0 shadow-sm p-3">
                        <h4 class="fw-bold">{{course.instructor_name}}</h5>
                            <p class="text-muted mb-1">Tổng học viên: {{course.instructor_total_students}}</p>
                            <p>{{course.instructor_bio}}</p>
                    </div>
                </section>
            </div>
        </div>
    </div>

    <hr>

    <!-- 5️⃣ Related courses -->
    <section class="mb-5">
        <h3 class="mb-4">5 khoá học khác cùng lĩnh vực</h3>
        <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 row-cols-xl-5 g-3">
            {{#each related}}
            <div class="col">
                {{> course_card}}
            </div>
            {{/each}}
        </div>
    </section>

    <hr>
    <!-- 7️⃣ Feedback -->
    <section class="mb-5">
        <h3 class="mb-3">Phản hồi của học viên</h3>
        {{#if feedback.length}}
        <div class="list-group">
            {{#each feedback}}
            <div class="list-group-item">
                <div class="d-flex justify-content-between">
                    <strong>{{this.student_name}}</strong>
                    <small class="text-muted">{{this.created_at}}</small>
                </div>
                <div class="text-warning mb-1">{{this.rating}} ★</div>
                <p class="mb-0">{{this.feedback}}</p>
            </div>
            {{/each}}
        </div>
        {{else}}
        <p class="text-muted">Chưa có phản hồi nào cho khoá học này.</p>
        {{/if}}
    </section>
</div>